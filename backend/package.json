{
  "name": "openresume-ai-backend",
  "version": "1.0.0",
  "description": "Node.js + LangGraph backend for OpenResume AI",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
